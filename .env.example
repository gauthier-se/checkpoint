# CheckPoint — example environment variables
#
# Copy this file to `.env` and fill in the values for local development:
#
#   cp .env.example .env
#
# RECOMMENDED: this project uses Doppler for secrets management (see README).
# `doppler run -- ./mvnw spring-boot:run` injects these variables for you.
#
# If you prefer a plain `.env` file, note that Spring Boot does NOT load it
# automatically. Export the variables into your shell before running the API:
#
#   cd api && export $(grep -v '^#' ../.env | xargs) && ./mvnw spring-boot:run
#
# All variables have sensible defaults in api/src/main/resources/application.properties,
# so the API boots without any of these set — but external integrations
# (IGDB, Steam, OAuth2) and a secure production setup require real values.

# --- IGDB API (via Twitch OAuth2) — required for game import & search ---
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# --- Steam Web API + OpenID 2.0 — required for Steam login/linking ---
STEAM_API_KEY=
STEAM_OPENID_REALM=http://localhost:3000
STEAM_OPENID_RETURN_URL=http://localhost:3000/api/auth/steam/openid/callback
STEAM_SIGNUP_TOKEN_TTL_MS=600000

# --- JWT — MUST be overridden with a strong secret in production ---
# Default is a development-only placeholder; never use it in production.
JWT_SECRET=
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# --- Frontend / cookies ---
# Public URL of the web app; used by OAuth2 redirect handlers.
FRONTEND_URL=http://localhost:3000
# Set to false for local HTTP development, true behind HTTPS in production.
COOKIE_SECURE=false

# --- API documentation (Swagger UI) ---
# Enabled by default in development; set to false in production to hide
# /swagger-ui.html and /v3/api-docs.
SWAGGER_ENABLED=true

# --- OAuth2 social login (optional) ---
# Login providers are only wired when both id and secret are set for a provider.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
