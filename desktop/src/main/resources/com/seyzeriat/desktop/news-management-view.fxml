<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.seyzeriat.desktop.controller.NewsManagementController"
      styleClass="users-view">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <!-- Header -->
    <Label text="Gestion des actualités" styleClass="view-title"/>

    <!-- Filters bar -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Rechercher par titre..." prefWidth="260"
                   styleClass="login-text-field"/>
        <ComboBox fx:id="statusFilter" prefWidth="160"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="newButton" text="Nouveau" onAction="#onNew" styleClass="login-button"/>
    </HBox>

    <!-- Status bar -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="statusLabel" styleClass="status-label"/>
        <Region HBox.hgrow="ALWAYS"/>

        <!-- Pagination -->
        <Button fx:id="prevButton" text="Précédent" onAction="#onPrevPage" styleClass="search-button"/>
        <Label fx:id="pageLabel" text="Page 1/1" styleClass="status-label"/>
        <Button fx:id="nextButton" text="Suivant" onAction="#onNextPage" styleClass="search-button"/>

        <Region minWidth="20"/>

        <Button fx:id="refreshButton" text="Actualiser" onAction="#onRefresh" styleClass="search-button"/>
        <ProgressIndicator fx:id="loadingIndicator" prefWidth="24" prefHeight="24"/>
    </HBox>

    <!-- News table -->
    <TableView fx:id="newsTable" VBox.vgrow="ALWAYS" styleClass="users-table">
        <columns>
            <TableColumn fx:id="titleColumn" text="Titre" prefWidth="260"/>
            <TableColumn fx:id="statusColumn" text="Statut" prefWidth="100"/>
            <TableColumn fx:id="authorColumn" text="Auteur" prefWidth="140"/>
            <TableColumn fx:id="sourceColumn" text="Source" prefWidth="120"/>
            <TableColumn fx:id="publishedAtColumn" text="Publié le" prefWidth="160"/>
            <TableColumn fx:id="updatedAtColumn" text="Mis à jour" prefWidth="160"/>
            <TableColumn fx:id="actionColumn" text="Actions" prefWidth="320"/>
        </columns>
        <placeholder>
            <Label text="Aucune actualité." styleClass="status-label"/>
        </placeholder>
    </TableView>
</VBox>
