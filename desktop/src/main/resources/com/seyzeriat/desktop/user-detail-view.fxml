<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.seyzeriat.desktop.controller.UserDetailController"
      styleClass="users-view">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <!-- Header with back button -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Retour" onAction="#onBack" styleClass="search-button"/>
        <Label fx:id="titleLabel" text="Détail de l'utilisateur" styleClass="view-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ProgressIndicator fx:id="loadingIndicator" prefWidth="24" prefHeight="24"/>
    </HBox>

    <!-- Status -->
    <Label fx:id="statusLabel" styleClass="status-label"/>

    <!-- User info grid -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="users-table">
        <VBox fx:id="detailContent" spacing="12">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15"/>
            </padding>

            <GridPane hgap="15" vgap="10">
                <columnConstraints>
                    <ColumnConstraints minWidth="140" prefWidth="140"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Username :" styleClass="status-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="usernameLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Email :" styleClass="status-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="emailLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Statut :" styleClass="status-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="bannedLabel" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Profil privé :" styleClass="status-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <Label fx:id="privateLabel" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="Niveau :" styleClass="status-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <Label fx:id="levelLabel" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <Label text="XP :" styleClass="status-label" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <Label fx:id="xpLabel" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                <Label text="Inscription :" styleClass="status-label" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <Label fx:id="createdAtLabel" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                <Label text="Avis rédigés :" styleClass="status-label" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                <Label fx:id="reviewCountLabel" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

                <Label text="Signalements reçus :" styleClass="status-label" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                <Label fx:id="reportCountLabel" GridPane.rowIndex="8" GridPane.columnIndex="1"/>

                <Label text="Photo de profil :" styleClass="status-label" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
                <Label fx:id="pictureLabel" GridPane.rowIndex="9" GridPane.columnIndex="1"/>

                <Label text="Bio :" styleClass="status-label" GridPane.rowIndex="10" GridPane.columnIndex="0"/>
                <Label fx:id="bioLabel" wrapText="true" GridPane.rowIndex="10" GridPane.columnIndex="1"/>
            </GridPane>

            <!-- Action buttons -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="10"/>
                </padding>
                <Button fx:id="clearBioBtn" text="Supprimer la bio" onAction="#onClearBio" styleClass="destructive-button"/>
                <Button fx:id="clearPictureBtn" text="Supprimer la photo" onAction="#onClearPicture" styleClass="destructive-button"/>
                <Button fx:id="banBtn" text="Bannir" onAction="#onToggleBan" styleClass="destructive-button"/>
            </HBox>
        </VBox>
    </ScrollPane>
</VBox>
