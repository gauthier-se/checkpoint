<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.seyzeriat.desktop.controller.ReportModerationController"
      styleClass="users-view">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <!-- Header -->
    <Label text="Modération des signalements" styleClass="view-title"/>

    <!-- Status bar -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="statusLabel" styleClass="status-label"/>
        <Region HBox.hgrow="ALWAYS"/>

        <!-- Pagination Controls -->
        <Button fx:id="prevButton" text="Précédent" onAction="#onPrevPage" styleClass="search-button"/>
        <Label fx:id="pageLabel" text="Page 1/1" styleClass="status-label"/>
        <Button fx:id="nextButton" text="Suivant" onAction="#onNextPage" styleClass="search-button"/>

        <Region minWidth="20"/>

        <Button fx:id="refreshButton" text="Actualiser" onAction="#onRefresh" styleClass="search-button"/>
        <ProgressIndicator fx:id="loadingIndicator" prefWidth="24" prefHeight="24"/>
    </HBox>

    <!-- Reports table -->
    <TableView fx:id="reportsTable" VBox.vgrow="ALWAYS" styleClass="users-table">
        <columns>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="140"/>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="80"/>
            <TableColumn fx:id="reporterColumn" text="Signalé par" prefWidth="120"/>
            <TableColumn fx:id="reasonColumn" text="Raison" prefWidth="180"/>
            <TableColumn fx:id="contentColumn" text="Contenu signalé" prefWidth="230"/>
            <TableColumn fx:id="actionColumn" text="Actions" prefWidth="240"/>
        </columns>
        <placeholder>
            <Label text="Aucun signalement." styleClass="status-label"/>
        </placeholder>
    </TableView>
</VBox>
